{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/moonlight-peaks/entity.schema.json",
  "title": "Moonlight Peaks Entity",
  "type": "object",
  "required": [
    "id",
    "name",
    "status",
    "source_refs"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "aliases": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "status": {
      "enum": [
        "confirmed",
        "probable",
        "hypothesis",
        "unknown",
        "corrected"
      ]
    },
    "game_version": {
      "type": [
        "string",
        "null"
      ]
    },
    "platform": {
      "type": [
        "string",
        "null"
      ]
    },
    "fields": {
      "type": "object",
      "additionalProperties": true
    },
    "source_refs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "source_id"
        ],
        "properties": {
          "source_id": {
            "type": "string"
          },
          "turn": {
            "type": [
              "integer",
              "null"
            ]
          },
          "media": {
            "type": [
              "string",
              "null"
            ]
          },
          "note": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "additionalProperties": true
      }
    },
    "notes": {
      "type": [
        "string",
        "null"
      ]
    },
    "history": {
      "type": "array",
      "items": {
        "type": "object"
      },
      "default": []
    }
  },
  "additionalProperties": true
}