{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Moonlight Peaks Observation",
  "type": "object",
  "required": [
    "id",
    "claim",
    "status",
    "source_refs"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "claim": {
      "type": "string"
    },
    "status": {
      "enum": [
        "confirmed",
        "probable",
        "hypothesis",
        "unknown",
        "corrected"
      ]
    },
    "subject_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "context": {
      "type": "object",
      "additionalProperties": true
    },
    "source_refs": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "supersedes": {
      "type": [
        "string",
        "null"
      ]
    },
    "notes": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "additionalProperties": true
}